{
  "info": {
    "_postman_id": "52b2d04d-1f76-4a50-8f66-0b00c19b7a21",
    "name": "CampusFlow API - Phase 1",
    "description": "Version-controlled API tests for the implemented CampusFlow health, course, and project endpoints. Run folders in order. The Cleanup folder removes records created by this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is JSON', function () {",
          "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "description": "Verify that Express and MySQL are available before running CRUD requests.",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health",
            "description": "Expected to confirm both the API and MySQL connection."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('API and database are healthy', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.status).to.eql('ok');",
                  "  pm.expect(body.data.database).to.eql('connected');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Courses",
      "description": "List, create, and validate courses. Create course stores its ID in the active environment as course_id.",
      "item": [
        {
          "name": "List courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Data is an array', function () {",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Course {{$timestamp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/courses",
            "description": "Creates a unique test course and stores response.data.id in course_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Created course has id and name', function () {",
                  "  pm.expect(body.data.id).to.be.a('number');",
                  "  pm.expect(body.data.name).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (pm.response.code === 201 && body.data?.id) {",
                  "  pm.environment.set('course_id', body.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject blank course name",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"   \"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/courses",
            "description": "Negative test for the required course name business rule."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Name validation error is returned', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Validation failed.');",
                  "  pm.expect(body.errors.name).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Projects",
      "description": "Project requests use course_id captured by Create course. Create project stores its ID as project_id.",
      "item": [
        {
          "name": "List projects by course",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/courses/{{course_id}}/projects"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Data is an array', function () {",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Test Project {{$timestamp}}\",\n  \"description\": \"Created by the CampusFlow Postman collection.\",\n  \"due_date\": \"2026-12-31\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/courses/{{course_id}}/projects",
            "description": "Creates a project under the captured course_id and stores response.data.id in project_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Created project matches selected course', function () {",
                  "  pm.expect(body.data.id).to.be.a('number');",
                  "  pm.expect(String(body.data.course_id)).to.eql(String(pm.environment.get('course_id')));",
                  "  pm.expect(body.data.due_date).to.eql('2026-12-31');",
                  "});",
                  "",
                  "if (pm.response.code === 201 && body.data?.id) {",
                  "  pm.environment.set('project_id', body.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject missing project fields",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"description\": null,\n  \"due_date\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/courses/{{course_id}}/projects",
            "description": "Negative test for required project title and due date."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Title and due date errors are returned', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.errors.title).to.be.a('string');",
                  "  pm.expect(body.errors.due_date).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "99 - Cleanup",
      "description": "Destructive test cleanup. Run only after the create requests have populated project_id and course_id.",
      "item": [
        {
          "name": "Delete test project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/projects/{{project_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Project deletion is confirmed', function () {",
                  "  pm.expect(pm.response.json().message).to.eql('Project deleted successfully.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete test course",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/courses/{{course_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Course deletion is confirmed', function () {",
                  "  pm.expect(pm.response.json().message).to.eql('Course deleted successfully.');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
